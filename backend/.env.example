# Copy to .env and fill in to enable live Google services.
# The app runs fully without any of these (deterministic CSV cache + fallback insights).

ENVIRONMENT=development

# Firebase / Firestore
USE_FIRESTORE=false
FIREBASE_PROJECT_ID=
# Also set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json in your shell/container

# Gemini (Google AI) — only LLM allowed by hackathon norms
USE_GEMINI=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

ALLOWED_ORIGINS=*
